# ====== Supabase (chưa bắt buộc cho bản demo local-first) ======
# Lấy tại: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chỉ dùng phía server (KHÔNG để lộ ra client):
SUPABASE_SERVICE_ROLE_KEY=

# ====== payOS (chuẩn bị sẵn cho tích hợp thanh toán) ======
# Lấy tại: https://my.payos.vn
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ====== Email (Resend hoặc Brevo) ======
RESEND_API_KEY=

# ====== Admin ======
# Email được phép vào /admin (cách nhau bởi dấu phẩy)
ADMIN_EMAILS=

# ====== App ======
# URL gốc của site, dùng cho webhook & email
NEXT_PUBLIC_SITE_URL=http://localhost:3000
